  },
  {
    "id": "esc-nel-next-line",
    "category": "two-byte-esc",
    "spec_ref": "VT100-UG: NEL",
    "input": "\\e[2J\\e[5;10H\\eE",
    "status": "supported",
    "expect": {
      "cursor": [
        6,
        1
      ],
      "state": {
