        "cur_col": 1
      }
    },
    "notes": "ESC E performs carriage return plus line feed."
  },
  {
    "id": "esc-ris-hard-reset-clears-screen",
    "category": "two-byte-esc",
    "spec_ref": "VT100-UG: RIS",
    "input": "\\e[3;12r\\e[7m\\e[12;30HBEFORE-RESET\\ec",
    "status": "supported",
    "expect": {
      "absent": [
        "BEFORE-RESET"
      ],
      "cursor": [
        1,
        1
      ],
      "state": {
        "scroll_top": 0,
        "scroll_bot": 23,
        "attr_inverse": 0
      }
    },
    "notes": "RIS clears the display, homes the cursor, resets attributes, and restores the full scroll region."
  },
  {
    "id": "esc-ris-resets-charset",
