[
  {
    "id": "esc-ind-cursor-down",
    "category": "two-byte-esc",
    "spec_ref": "VT100-UG: IND",
    "input": "\\e[2J\\e[5;10H\\eD",
    "status": "supported",
    "expect": {
      "cursor": [
        6,
        10
      ],
      "state": {
        "cur_row": 6,
        "cur_col": 10
      }
    },
    "notes": "ESC D indexes one row down without changing the column."
  },
  {
    "id": "esc-ind-scroll-bottom",
    "category": "two-byte-esc",
    "spec_ref": "VT100-UG: IND",
    "input": "\\e[23;1HNEARBOT\\e[24;1H\\eD",
    "status": "supported",
    "expect": {
      "rows": [
        [
          22,
          1,
          "NEARBOT"
        ]
      ],
      "cursor": [
        24,
        1
      ]
    },
    "notes": "IND at the bottom margin scrolls the region up."
  },
  {
    "id": "esc-ri-cursor-up",
