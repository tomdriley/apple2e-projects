  },
  {
    "id": "c0-lf-down-one-row",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 LF; VT100-UG",
    "input": "\\e[2J\\e[6;20H\\n",
    "status": "supported",
    "expect": {
      "cursor": [
        7,
        20
      ]
    },
    "notes": "LF moves down one row and preserves the column."
  },
  {
    "id": "c0-lf-scrolls-at-bottom-margin",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 LF; VT100-UG",
    "input": "\\e[2J\\e[23;1HONE\\e[24;1HTWO\\n",
    "status": "supported",
    "expect": {
      "rows": [
        [
          22,
          1,
          "ONE"
        ],
        [
          23,
          1,
          "TWO"
        ],
        [
          24,
          1,
          "   "
        ]
      ],
      "cursor": [
        24,
        4
      ]
    },
    "notes": "LF at the bottom margin scrolls content up and leaves a blank bottom line."
  },
  {
    "id": "c0-vt-ignored",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 VT; VT100-UG",
    "input": "\\e[2J\\e[5;10HVT\\v",
    "status": "supported",
    "basis": "spec",
    "expect": {
      "rows": [
        [
          5,
          10,
          "VT"
        ]
      ],
      "cursor": [
        6,
        12
      ]
    },
