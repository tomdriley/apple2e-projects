    "status": "supported",
    "expect": {
      "cursor": [
        9,
        80
      ]
    },
    "notes": "HT near the right edge clamps at column 80."
  },
  {
    "id": "c0-cr-to-column-one",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 CR; VT100-UG",
    "input": "\\e[2J\\e[6;20H\\r",
    "status": "supported",
    "expect": {
      "cursor": [
        6,
        1
      ]
    },
