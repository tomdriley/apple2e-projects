    "basis": "spec",
    "expect": {
      "rows": [
        [
          5,
          10,
          "FF"
        ]
      ],
      "cursor": [
        6,
        12
      ]
    },
    "notes": "FF acts as LF: the cursor moves down one row with the column preserved (LNM off, so no CR)."
  },
  {
    "id": "c0-so-ignored",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 SO; VT100-UG",
    "input": "\\e[2J\\e[5;10HSO\\x0e",
    "status": "supported",
    "basis": "tolerance",
    "expect": {
      "rows": [
        [
          5,
          10,
          "SO"
