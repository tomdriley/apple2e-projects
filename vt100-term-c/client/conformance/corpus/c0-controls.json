[
  {
    "id": "c0-bel-no-display-change",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 BEL; VT100-UG",
    "input": "\\e[2J\\e[5;10HOK\\a",
    "status": "supported",
    "expect": {
      "rows": [
        [
          5,
          10,
          "OK"
        ]
      ],
      "cursor": [
        5,
        12
      ]
    },
    "notes": "BEL clicks the speaker and does not alter the glyph plane or cursor."
  },
  {
    "id": "c0-bs-left-one-column",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 BS; VT100-UG",
    "input": "\\e[2J\\e[5;10H\\b",
    "status": "supported",
    "expect": {
      "cursor": [
        5,
        9
      ]
    },
    "notes": "BS moves the cursor one column left without erasing."
  },
  {
    "id": "c0-bs-overwrite-no-erase",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 BS; VT100-UG",
    "input": "\\e[2J\\e[5;10HAB\\bC",
    "status": "supported",
    "expect": {
      "rows": [
        [
          5,
          10,
          "AC"
        ]
      ],
      "cursor": [
        5,
        12
      ]
    },
    "notes": "BS permits overwriting the previous cell and does not erase by itself."
  },
  {
    "id": "c0-bs-clamps-at-column-one",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 BS; VT100-UG",
    "input": "\\e[2J\\e[5;1H\\b",
    "status": "supported",
    "expect": {
      "cursor": [
        5,
        1
      ]
    },
    "notes": "BS at the left edge clamps at column 1."
  },
  {
    "id": "c0-ht-from-column-one",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 HT; VT100-UG",
    "input": "\\e[2J\\e[1;1H\\t",
    "status": "supported",
    "expect": {
      "cursor": [
        1,
        9
      ]
    },
    "notes": "HT advances from column 1 to the next 8-column tab stop at column 9."
  },
  {
    "id": "c0-ht-from-arbitrary-column",
    "category": "c0-controls",
