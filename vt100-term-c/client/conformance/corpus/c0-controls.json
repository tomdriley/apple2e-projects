    "status": "supported",
    "expect": {
      "cursor": [
        7,
        17
      ]
    },
    "notes": "HT from an arbitrary column advances to the next 8-column tab stop."
  },
  {
    "id": "c0-ht-clamps-at-right-edge",
    "category": "c0-controls",
    "spec_ref": "ECMA-48 §8.3 HT; VT100-UG",
